classDiagram
    %% PawPal+ class diagram based on initial UML brainstorm.
    %% Core actions: add a pet, schedule a walk, see today's tasks.

    class Owner {
        +String name
        +String experience
        +ownsPet() void
    }

    class Pet {
        +String name
        +String animal
        +eat() void
        +sleep() void
    }

    class Walk {
        +String time
        +schedule() void
        +cancel() void
    }

    class Schedule {
        +String event
        +String time
        +listTodaysTasks() List
    }

    Owner "1" --> "*" Pet : owns
    Owner --> Schedule : maintains
    Schedule "1" --> "*" Walk : contains
    Walk --> Pet : for
